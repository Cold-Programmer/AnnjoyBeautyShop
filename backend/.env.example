# ==========================================
# GLOW 'N' GO BEAUTY & COSMETICS — BACKEND ENVIRONMENT
# ==========================================

PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ==========================================
# Database (PostgreSQL + Prisma)
# ==========================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/glow_n_go

# ==========================================
# JWT
# Generate your own long random secrets before production.
# ==========================================
JWT_ACCESS_SECRET=replace_with_a_64_character_random_secret_here
JWT_REFRESH_SECRET=replace_with_a_different_64_character_random_secret_here
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# ==========================================
# Base URL
# ==========================================
BASE_URL=https://judgingly-specked-bagel.ngrok-free.dev

# ==========================================
